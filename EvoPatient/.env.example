# ====== API 配置 ======
# OpenAI 兼容 API 端点
BASE_URL=https://api.openai.com/v1

# API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here

# ====== 模型配置 ======
# 主力对话模型（用于患者回答生成、医生提问、诊断总结等核心任务）
LLM_MODEL=gpt-4o

# 轻量模型（用于质量评估、问题检测等轻量任务）
LLM_LITE_MODEL=gpt-4o-mini

# 向量模型（用于 Q&A 演化检索和 RAG 检索）
EMBEDDING_MODEL=text-embedding-ada-002
